{
  "title": "Booking App",
  "uid": "booking-app",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "timezone": "browser",
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "요청량 (총량)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({container_name=\"booking-app\"} | json | status!=\"\" [$__interval]))"
        }
      ]
    },
    {
      "id": 2,
      "title": "상태코드별 분포",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (status) (count_over_time({container_name=\"booking-app\"} | json | status!=\"\" [$__interval]))"
        }
      ]
    },
    {
      "id": 3,
      "title": "에러율 (5xx / 전체)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({container_name=\"booking-app\"} | json | status>=500 [$__interval])) / sum(count_over_time({container_name=\"booking-app\"} | json | status!=\"\" [$__interval]))"
        }
      ]
    },
    {
      "id": 4,
      "title": "에러 로그 목록",
      "type": "logs",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{container_name=\"booking-app\"} | json | level=\"ERROR\""
        }
      ]
    },
    {
      "id": 5,
      "title": "응답시간 (평균 / p95, ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "legendFormat": "avg",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "avg_over_time({container_name=\"booking-app\"} | json | status!=\"\" | unwrap duration_ms [$__interval])"
        },
        {
          "refId": "B",
          "legendFormat": "p95",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "quantile_over_time(0.95, {container_name=\"booking-app\"} | json | status!=\"\" | unwrap duration_ms [$__interval])"
        }
      ]
    }
  ]
}
